# Fanqie Short Novel - 环境变量配置
# 复制此文件为 .env 并修改配置

# LLM 模型配置（必填）
# 支持任何 OpenAI 兼容接口：DeepSeek / 通义千问 / 智谱 / Ollama 等
LLM_BASE_URL=https://api.deepseek.com
LLM_API_KEY=your_api_key_here
LLM_MODEL=deepseek-v4-flash
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4000

# 应用配置
APP_NAME=Fanqie Short Novel
DEBUG=false
SECRET_KEY=change_me_in_production

# 数据库路径（默认在项目 data 目录下，无需修改）
# DATABASE_PATH=data/fanqie_short_novel.db

# 服务端口
HOST=127.0.0.1
PORT=8001
